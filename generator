<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>lekcjaw5minut.pl | Generator Testów i Kart Pracy</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap');

        :root {
            --brand-navy: #0f172a;
            --brand-orange: #f59e0b;
            --brand-blue: #3b82f6;
            --brand-indigo: #6366f1;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #fdfdfd;
            color: #1e293b;
            margin: 0;
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* Dynamiczne tło */
        .bg-mesh {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            z-index: -2;
            background-color: #ffffff;
            background-image: 
                radial-gradient(at 0% 0%, rgba(59, 130, 246, 0.05) 0px, transparent 50%),
                radial-gradient(at 100% 0%, rgba(245, 158, 11, 0.05) 0px, transparent 50%),
                radial-gradient(at 100% 100%, rgba(99, 102, 241, 0.05) 0px, transparent 50%),
                radial-gradient(at 0% 100%, rgba(59, 130, 246, 0.05) 0px, transparent 50%);
        }

        .grid-overlay {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background-image: linear-gradient(rgba(0,0,0,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(0,0,0,0.03) 1px, transparent 1px);
            background-size: 50px 50px;
            z-index: -1;
            mask-image: radial-gradient(ellipse at center, black, transparent 80%);
        }

        .blob {
            position: absolute;
            width: 600px; height: 600px;
            background: linear-gradient(135deg, var(--brand-blue), var(--brand-indigo));
            filter: blur(140px);
            border-radius: 50%;
            opacity: 0.12;
            z-index: -1;
            pointer-events: none;
            transition: all 1.5s cubic-bezier(0.23, 1, 0.32, 1);
        }

        /* Glassmorphism */
        .glass-card {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.5);
            box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.04);
        }

        .logo-text {
            font-weight: 800;
            letter-spacing: -0.04em;
            color: var(--brand-navy);
        }

        .highlight-orange {
            background: linear-gradient(to right, #f59e0b, #ea580c);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .feature-card {
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            border: 1px solid transparent;
        }

        .feature-card:hover {
            transform: translateY(-8px);
            background: white;
            border-color: rgba(59, 130, 246, 0.2);
            box-shadow: 0 25px 40px -10px rgba(0, 0, 0, 0.05);
        }

        .btn-primary {
            background: var(--brand-navy);
            box-shadow: 0 10px 20px -5px rgba(15, 23, 42, 0.2);
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 15px 30px -5px rgba(15, 23, 42, 0.3);
        }

        .badge {
            background: rgba(59, 130, 246, 0.1);
            color: var(--brand-blue);
            font-size: 0.75rem;
            font-weight: 700;
            padding: 4px 12px;
            border-radius: 99px;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        /* Animation for icons */
        .icon-bounce:hover i {
            animation: bounce 0.5s ease;
        }

        @keyframes bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-5px); }
        }
    </style>
</head>
<body class="flex flex-col items-center">

    <div class="bg-mesh"></div>
    <div class="grid-overlay"></div>
    <div class="blob" id="cursorBlob"></div>

    <!-- Nawigacja -->
    <nav class="w-full max-w-6xl px-6 py-8 flex justify-between items-center z-10">
        <div class="logo-text text-2xl cursor-default">
            lekcja<span class="highlight-orange">w5minut</span><span class="text-slate-400">.pl</span>
        </div>
        <div class="flex items-center gap-6">
            <a href="#" class="text-slate-600 hover:text-blue-600 font-medium transition-colors hidden md:block">Moje Materiały</a>
            <button class="group flex items-center gap-2 text-slate-500 hover:text-slate-900 transition-all font-medium">
                <span class="text-sm">Zaloguj</span>
                <div class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center group-hover:bg-slate-200 transition-colors">
                    <i class="fas fa-user text-[10px]"></i>
                </div>
            </button>
        </div>
    </nav>

    <!-- Sekcja Hero -->
    <main class="w-full max-w-6xl px-6 py-12 md:py-20 flex flex-col items-center text-center relative">
    
        
        <h1 class="text-5xl md:text-7xl logo-text mb-8 leading-[1.1] tracking-tight max-w-4xl">
            Testy i karty pracy, które <br>
            <span class="text-blue-600">tworzą się same.</span>
        </h1>

        <p class="text-slate-500 text-lg md:text-xl mb-12 max-w-2xl leading-relaxed">
            Budujemy generator dla Ciebie!
        </p>


        <!-- Siatka Funkcji -->
        <div class="grid md:grid-cols-3 gap-8 w-full">
            <!-- Karta 1 -->
            <div class="feature-card glass-card p-10 rounded-[2.5rem] text-left relative overflow-hidden group">
                <div class="absolute -right-4 -top-4 w-24 h-24 bg-blue-500/5 rounded-full transition-transform group-hover:scale-150"></div>
                <div class="w-14 h-14 bg-blue-100 text-blue-600 rounded-2xl flex items-center justify-center mb-8 text-2xl icon-bounce">
                    <i class="fas fa-file-lines"></i>
                </div>
                <h3 class="text-2xl font-bold mb-4">Różne typy zadań</h3>
                <p class="text-slate-500 leading-relaxed mb-6">
                    Pytania zamknięte, otwarte, prawda/fałsz oraz zadania na dobieranie. Ty decydujesz o proporcjach.
                </p>
                <ul class="space-y-3 text-sm font-medium text-slate-600">
                    <li class="flex items-center gap-2"><i class="fas fa-check text-green-500"></i> wielokrotny wybór</li>
                    <li class="flex items-center gap-2"><i class="fas fa-check text-green-500"></i> Uzupełnianie luk</li>
                    <li class="flex items-center gap-2"><i class="fas fa-check text-green-500"></i> Zadania z rysunkiem</li>
                    <li class="flex items-center gap-2"><i class="fas fa-check text-green-500"></i> Prawda/Fałsz</li>
                    <li class="flex items-center gap-2"><i class="fas fa-check text-green-500"></i> Zadanie otwarte</li>
                    <li class="flex items-center gap-2"><i class=" text-green-500"></i> I wiele więcej...</li>
                </ul>
            </div>

            <!-- Karta 2 -->
            <div class="feature-card glass-card p-10 rounded-[2.5rem] text-left relative overflow-hidden group border-blue-100">
                <div class="absolute -right-4 -top-4 w-24 h-24 bg-orange-500/5 rounded-full transition-transform group-hover:scale-150"></div>
                <div class="w-14 h-14 bg-orange-100 text-orange-600 rounded-2xl flex items-center justify-center mb-8 text-2xl icon-bounce">
                    <i class="fas fa-layer-group"></i>
                </div>
                <h3 class="text-2xl font-bold mb-4">Grupy A i B oraz C i D</h3>
                <p class="text-slate-500 leading-relaxed mb-6">
                    Jednym kliknięciem stwórz alternatywne wersje tego samego testu, aby zminimalizować ściąganie w klasie.
                </p>
                <ul class="space-y-3 text-sm font-medium text-slate-600">
                    <li class="flex items-center gap-2"><i class="fas fa-check text-orange-500"></i> Mieszanie kolejności pytań</li>
                    <li class="flex items-center gap-2"><i class="fas fa-check text-orange-500"></i> Zmiana parametrów zadań</li>
                    <li class="flex items-center gap-2"><i class="fas fa-check text-orange-500"></i> Klucze odpowiedzi dla wszystkich grup</li>
                </ul>
            </div>

            <!-- Karta 3 -->
            <div class="feature-card glass-card p-10 rounded-[2.5rem] text-left relative overflow-hidden group">
                <div class="absolute -right-4 -top-4 w-24 h-24 bg-indigo-500/5 rounded-full transition-transform group-hover:scale-150"></div>
                <div class="w-14 h-14 bg-indigo-100 text-indigo-600 rounded-2xl flex items-center justify-center mb-8 text-2xl icon-bounce">
                    <i class="fas fa-file-export"></i>
                </div>
                <h3 class="text-2xl font-bold mb-4">Eksport do PDF</h3>
                <p class="text-slate-500 leading-relaxed mb-6">
                    Pobierz gotowe materiały SZYBKO i SPRAWNIE.
                </p>
            </div>
        </div>

        <!-- Sekcja Statystyk -->
        <div class="mt-32 w-full grid grid-cols-2 md:grid-cols-4 gap-8 py-12 border-y border-slate-100">
            <div class="flex flex-col items-center">
                <span class="text-4xl font-extrabold text-slate-900 mb-2">500k+</span>
                <span class="text-slate-400 text-sm font-bold uppercase tracking-wider">Pytań w bazie</span>
            </div>
            <div class="flex flex-col items-center">
                <span class="text-4xl font-extrabold text-slate-900 mb-2">12k</span>
                <span class="text-slate-400 text-sm font-bold uppercase tracking-wider">Nauczycieli</span>
            </div>
            <div class="flex flex-col items-center">
                <span class="text-4xl font-extrabold text-slate-900 mb-2">5 min</span>
                <span class="text-slate-400 text-sm font-bold uppercase tracking-wider">Czas tworzenia</span>
            </div>
            <div class="flex flex-col items-center">
                <span class="text-4xl font-extrabold text-slate-900 mb-2">100%</span>
                <span class="text-slate-400 text-sm font-bold uppercase tracking-wider">Zgodność z PP</span>
            </div>
        </div>
    </main>

    <!-- Stopka -->
    <footer class="w-full max-w-6xl px-6 py-12 mt-auto flex flex-col md:flex-row justify-between items-center gap-6 text-slate-400 text-sm border-t border-slate-100">
        <div class="flex items-center gap-2">
            <div class="w-6 h-6 bg-slate-100 rounded flex items-center justify-center text-[10px] text-slate-400">
                <i class="fas fa-shield-alt"></i>
            </div>
            &copy; 2026 lekcjaw5minut.pl. Technologia wspierająca edukację.
        </div>
        <div class="flex gap-8">
            <a href="mailto:bok@lekcjaw5minut.pl" class="hover:text-blue-600 transition-colors">Centrum Pomocy</a>
            <a href="/files/regulamin%20serwisu_Lekcjaw5min.pl.pdf" class="hover:text-blue-600 transition-colors">Regulamin</a>
        </div>
    </footer>

    <script>
        // --- INTERAKTYWNE TŁO ---
        document.addEventListener('mousemove', (e) => {
            const blob = document.getElementById('cursorBlob');
            if (blob) {
                const x = e.clientX;
                const y = e.clientY;
                // Płynne podążanie z lekkim offsetem
                blob.style.transform = `translate(${x - 300}px, ${y - 300}px)`;
            }
        });

        // Dodanie efektu paralaksy na karty przy scrollu
        window.addEventListener('scroll', () => {
            const cards = document.querySelectorAll('.feature-card');
            const scrolled = window.pageYOffset;
            
            cards.forEach((card, index) => {
                const speed = 0.05 + (index * 0.02);
                card.style.transform = `translateY(${scrolled * speed * -1}px)`;
            });
        });
    </script>
</body>
</html>
